# Firebase Configuration
# Copia este archivo a .env.local y completa con tus credenciales de Firebase

NEXT_PUBLIC_FIREBASE_API_KEY=tu_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=tu_app_id

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=+34612345678
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola%20Pablo,%20quiero%20información%20sobre%20los%20entrenamientos%20de%20natación
